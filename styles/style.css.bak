/* Door Opening Animation */
.door-overlay { position: fixed; inset: 0; z-index: 2000; display: grid; place-items: center; pointer-events: none; }
.door-panel { position: absolute; top: 0; bottom: 0; width: 50vw; background: var(--bg); z-index: 1; transition: transform 1.2s cubic-bezier(0.6, 0.05, 0.01, 0.9); will-change: transform; }
.door-left { left: 0; transform-origin: left; }
.door-right { right: 0; transform-origin: right; }
.door-brand { position: relative; z-index: 2; font-family: var(--font-primary); font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 700; color: var(--text); opacity: 1; transition: opacity 0.5s ease; }

.door-open .door-left { transform: translateX(-100%); }
.door-open .door-right { transform: translateX(100%); }
.door-open .door-brand { opacity: 0; }

