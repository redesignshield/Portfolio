/*
  Redesign Shield - Portfolio Styles
  - Responsive CSS with CSS variables for theming
  - Light/Dark themes
  - Fluid typography, grid utilities, components, animations
*/

/* CSS Reset (modern minimal) */
*, *::before, *::after { box-sizing: border-box; }
* { margin: 0; }
html:focus-within { scroll-behavior: smooth; }
html, body { height: 100%; }
body { line-height: 1.5; -webkit-font-smoothing: antialiased; }
img, picture, video, canvas, svg { display: block; max-width: 100%; }
input, button, textarea, select { font: inherit; }
:target { scroll-margin-top: 8rem; }

/* Theme variables */
:root {
  --font-primary: 'Arvo', serif;
  --font-secondary: 'Dosis', sans-serif;
  --step--2: clamp(0.76rem, calc(0.71rem + 0.23vw), 0.88rem);
  --step--1: clamp(0.87rem, calc(0.80rem + 0.30vw), 1.00rem);
  --step-0: clamp(1.00rem, calc(0.90rem + 0.40vw), 1.13rem);
  --step-1: clamp(1.13rem, calc(1.01rem + 0.52vw), 1.27rem);
  --step-2: clamp(1.27rem, calc(1.14rem + 0.68vw), 1.42rem);
  --step-3: clamp(1.42rem, calc(1.28rem + 0.88vw), 1.60rem);
  --step-4: clamp(1.60rem, calc(1.44rem + 1.14vw), 1.80rem);
  --step-5: clamp(1.80rem, calc(1.62rem + 1.47vw), 2.03rem);

  --radius: 14px;
  --radius-sm: 10px;
  --radius-lg: 24px;
  --shadow-1: 0 10px 30px rgba(0,0,0,.10);
  --shadow-2: 0 20px 50px rgba(0,0,0,.18);

  --space-1: clamp(8px, 1vw, 12px);
  --space-2: clamp(12px, 1.5vw, 18px);
  --space-3: clamp(16px, 2vw, 24px);
  --space-4: clamp(24px, 3vw, 36px);
  --space-5: clamp(32px, 4vw, 48px);
  --space-6: clamp(48px, 6vw, 72px);

  --maxw: 1200px;

  /* Light theme */
  --bg: #0f1221;
  --card: #171a2c;
  --text: #e8ecff;
  --muted: #b9c0e6;
  --brand: #0e4eb5; /* Deep Blue from logo */
  --brand-2: #f55f44; /* Orange/Red from logo */
  --accent: #2c6cd1; /* Lighter blue */
  --line: rgba(255,255,255,.08);
}

body[data-theme="light"] {
  --bg: #f6f7fb;
  --card: #ffffff;
  --text: #1b1e2f;
  --muted: #4b5675;
  --brand: #0e4eb5; /* Deep Blue */
  --brand-2: #dc3e26; /* Redder for light mode */
  --accent: #2c6cd1;
  --line: rgba(0,0,0,.08);
}

/* Base */
body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--font-secondary);
  font-size: var(--step-0);
}

.container { max-width: var(--maxw); margin-inline: auto; padding-inline: var(--space-3); }
.section { padding-block: var(--space-6); position: relative; }
.section h2 { font-family: var(--font-primary); font-size: var(--step-4); margin-bottom: var(--space-3); letter-spacing: 0.5px; }

p { color: var(--muted); }

/* Header */
.header { position: fixed; width: 100%; top: 0; left: 0; z-index: 1000; backdrop-filter: saturate(180%) blur(12px); background: color-mix(in oklab, var(--bg) 80%, transparent); border-bottom: 1px solid var(--line); transition: transform 0.3s ease; }
.header__inner { display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: var(--space-3); height: 72px; }
.brand { display: inline-flex; align-items: center; gap: 10px; text-decoration: none; color: var(--text); font-weight: 700; font-family: var(--font-primary); }
.brand__logo { height: 32px; width: auto; }
.brand__logo--dark { display: none; }
body[data-theme="dark"] .brand__logo--dark { display: block; }
body[data-theme="dark"] .brand__logo--light { display: none; }
.brand__name { font-size: var(--step-1); }

.nav { justify-self: center; }
.nav--full { width: 100%; }
.nav--full .nav__menu { justify-content: center; }
.nav__menu { display: flex; gap: var(--space-3); list-style: none; }
.nav__menu a { color: var(--text); text-decoration: none; padding: 8px 10px; border-radius: 8px; position: relative; isolation: isolate; font-weight: 700; letter-spacing: .2px; }
.nav__menu a::after { content: ""; position: absolute; inset: auto 0 0 0; height: 2px; background: var(--brand); transform: scaleX(0); transform-origin: right; transition: transform .3s ease; }

.nav__menu a:hover::after, .nav__menu a:focus::after { transform: scaleX(1); transform-origin: left; }

.nav__toggle { display: none; flex-direction: column; gap: 4px; width: 40px; height: 40px; border: 1px solid var(--line); border-radius: 8px; background: transparent; color: var(--text); align-items: center; justify-content: center; }
.nav__toggle span { display: block; width: 18px; height: 2px; background: var(--text); }

.header__actions { display: flex; align-items: center; gap: var(--space-2); }

/* Buttons */
/* Buttons - Unique Hover Animation */
.btn { --_bg: var(--brand); --_color: #fff; display: inline-flex; align-items: center; justify-content: center; gap: 8px; padding: 10px 24px; border-radius: 30px; border: none; color: var(--_color); background: var(--_bg); cursor: pointer; text-decoration: none; position: relative; overflow: hidden; isolation: isolate; font-weight: 600; letter-spacing: 0.5px; transition: transform .2s ease, box-shadow .2s ease, filter .2s ease; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
.btn::before { content: ""; position: absolute; inset: -2px; background: rgba(255,255,255,0.1); opacity: 0; transition: opacity .25s ease; pointer-events: none; }
.btn::after { content: ""; position: absolute; inset: 1px; border-radius: inherit; background: rgba(255,255,255,0.05); mix-blend-mode: overlay; opacity: .18; pointer-events: none; }
.btn:hover { transform: translateY(-2px); box-shadow: 0 12px 30px rgba(0,0,0,0.22); filter: saturate(1.08); }
.btn:hover::before { opacity: 1; }
.btn:active { transform: translateY(0); }
.btn--primary { --_bg: var(--brand); }
.btn--secondary { --_bg: var(--brand-2); }
.btn--ghost { --_bg: color-mix(in oklab, var(--bg) 86%, var(--text)); --_color: var(--text); }

/* Grid utilities */
.grid { display: grid; gap: var(--space-4); }
.two-col { grid-template-columns: repeat(2, minmax(0, 1fr)); align-items: center; }
.three-col { grid-template-columns: repeat(3, minmax(0, 1fr)); }


/* Hero */
.section--hero { padding-top: calc(var(--space-6) + 32px); }
.hero__grid { display: grid; grid-template-columns: 1.1fr 0.9fr; align-items: center; gap: var(--space-4); min-height: min(84vh, 820px); }
.hero__title { font-family: var(--font-primary); font-size: clamp(2rem, 3.5vw + 1rem, 4rem); line-height: 1.1; }
.hero__subtitle { margin-top: var(--space-2); font-size: var(--step-1); max-width: 56ch; }
.hero__tabs { margin-top: var(--space-3); display: grid; gap: 10px; max-width: 62ch; }
.hero__tab { display: grid; grid-template-columns: 40px 1fr; align-items: center; gap: 10px; padding: 8px 0; border-radius: 0; background: transparent; border: 0; box-shadow: none; cursor: pointer; text-align: left; transition: transform .22s ease, filter .22s ease; }
.hero__tabLottie { width: 36px; height: 36px; border-radius: 10px; background: transparent; }
.hero__tabText { font-weight: 800; letter-spacing: .2px; color: color-mix(in oklab, var(--text) 86%, var(--muted)); }
.hero__tab:hover { transform: translateX(4px); filter: saturate(1.05); }
.hero__tab.is-active { transform: translateX(6px); }
.hero__tab.is-active .hero__tabText { color: var(--text); }
.hero__actions { margin-top: var(--space-3); display: flex; gap: var(--space-2); flex-wrap: wrap; }
.hero__right { min-height: 360px; display: grid; place-items: center; }
.hero__right--bare { background: transparent; box-shadow: none; border-radius: 0; overflow: visible; position: relative; }
.hero__right--bare::after { content: none; }
.hero__lotties { display: none; }
.hero__right--bare {
  min-height: 400px;
  background: var(--card) !important;
  border-radius: var(--radius) !important;
  border: 1px solid var(--line) !important;
  display: flex !important;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden !important;
}
/* Placeholder for Hero Image */
.hero__right--bare::before {
  content: "Hero Image";
  color: var(--muted);
  font-weight: 700;
  font-size: 1.5rem;
  z-index: 2;
}
.hero__right--bare::after {
  content: "";
  position: absolute;
  inset: 0;
  background: var(--brand);
  opacity: 0.1;
  z-index: 1;
}

/* Text rotate animation */
.txt-rotate { display: inline-block; background: transparent; -webkit-background-clip: unset; background-clip: unset; color: var(--brand); }


/* Cards, KPI, Highlights */
.cards { display: grid; gap: var(--space-3); grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
.card, .kpi, .highlight { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: var(--space-3); box-shadow: var(--shadow-1); }
.kpis { grid-template-columns: repeat(3, minmax(0, 1fr)); }
.kpi { text-align: center; }
.kpi__num { font-size: clamp(1.8rem, 2.6vw + 1rem, 3rem); font-family: var(--font-primary); }
.kpi__label { color: var(--muted); }

/* Services cards hover */
.card { position: relative; overflow: hidden; }
.card::before { content: ""; position: absolute; inset: -40% auto auto -40%; width: 120px; height: 120px; background: color-mix(in oklab, var(--accent) 36%, transparent); transform: translate(var(--mx, 0), var(--my, 0)); opacity: .5; transition: transform .2s ease; pointer-events: none; border-radius: 50%; filter: blur(40px); }

.card:hover::before { opacity: .8; }

/* Why Me pill */
.pill-group { display: flex; gap: 10px; flex-wrap: wrap; margin-top: var(--space-2); }
.pill { background: color-mix(in oklab, var(--brand) 18%, var(--card)); border: 1px solid var(--line); padding: 6px 12px; border-radius: 100px; font-weight: 600; }
.media-blob { min-height: 260px; border-radius: 50%; background: var(--brand); opacity: 0.2; filter: blur(40px); box-shadow: var(--shadow-2); }

/* About Section Styles */
.section--about { overflow: hidden; }
.section--about .container { position: relative; z-index: 1; }
.section--about::after { content: ""; position: absolute; inset: -120px -140px auto auto; width: min(520px, 60vw); height: min(520px, 60vw); background: var(--accent); filter: blur(100px); opacity: .15; pointer-events: none; border-radius: 50%; }

.about__content { position: relative; z-index: 2; }
.about__content h2 { color: var(--brand); }
.about__content p { max-width: 60ch; }
.about__visual { position: relative; min-height: 400px; display: grid; place-items: center; }
.about__visual::before { content: ""; position: absolute; inset: 12% 10%; border-radius: 40% 60% 50% 50% / 50% 50% 60% 40%; background: var(--brand); filter: blur(60px); opacity: .2; transform: rotate(-8deg); }

.about__lottie { width: 100%; height: 100%; max-width: 500px; transform: scale(1.1); filter: drop-shadow(0 20px 40px rgba(0,0,0,0.1)); z-index: 1; }
.about__stats { margin-top: var(--space-3); display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; z-index: 2; }
.about__stats .kpi { padding: 12px 18px; backdrop-filter: blur(12px); background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255, 255, 255, 0.2); border-left: 4px solid var(--accent); border-radius: 12px; box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1); transform: translateY(0); transition: transform 0.3s ease; pointer-events: auto; text-align: left; min-width: 160px; }
.about__stats .kpi:hover { transform: translateY(-5px); background: rgba(255, 255, 255, 0.15); }
.about__stats .kpi__num { font-size: 1.8rem; display: block; line-height: 1; color: var(--text); font-weight: 700; }
.about__stats .kpi__label { font-size: 0.85rem; color: var(--muted); font-weight: 500; }
body[data-theme="light"] .about__stats .kpi { background: rgba(255, 255, 255, 0.7); }
.why__visual { min-height: 280px; display: grid; place-items: center; background: transparent; }
.why__visual dotlottie-wc { background: transparent !important; }

@media (max-width: 900px) {
  /* Moved to responsive.css */
}

/* Portfolio grid */
.portfolio__grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: var(--space-3); }
.portfolio__item { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-1); transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease; position: relative; }
.portfolio__item::before { content: ""; position: absolute; inset: 0; background: rgba(255,255,255,0.1); transform: translateX(-120%); transition: transform .7s ease; pointer-events: none; }

.portfolio__item:hover { transform: translateY(-6px); box-shadow: var(--shadow-2); border-color: color-mix(in oklab, var(--brand) 28%, var(--line)); }
.portfolio__item:hover::before { transform: translateX(120%); }
.portfolio__item img { aspect-ratio: 3 / 2; object-fit: cover; transition: transform .5s cubic-bezier(.2,.8,.2,1); }
.portfolio__item:hover img { transform: scale(1.04); }
.portfolio__item figcaption { padding: 12px 14px; font-weight: 700; transition: transform .25s ease; }
.portfolio__item:hover figcaption { transform: translateY(-2px); }

/* Testimonials */
.testimonial__slider { display: grid; gap: var(--space-3); grid-template-columns: repeat(2, minmax(260px, 1fr)); }

.testimonial { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: var(--space-3); font-style: italic; display: block; opacity: 1; transform: none; }
.testimonial footer { margin-top: var(--space-2); color: var(--muted); font-style: normal; }

/* FAQ */
.section--faq details { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: var(--space-2); margin-bottom: var(--space-2); box-shadow: var(--shadow-1); overflow: hidden; }
.section--faq details:hover { border-color: color-mix(in oklab, var(--brand) 28%, var(--line)); box-shadow: var(--shadow-2); transform: translateY(-2px); transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease; }
.section--faq summary { cursor: pointer; font-weight: 700; }
.section--faq details > *:not(summary) { animation: faqOpen .25s ease; }
@keyframes faqOpen { from { opacity: 0; transform: translateY(-4px); } to { opacity: 1; transform: translateY(0); } }

/* FAQ: click/open answer animation */
.section--faq details[open] > *:not(summary) { animation: faqAnswer .35s cubic-bezier(.2,.8,.2,1); }
@keyframes faqAnswer { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }

/* CTA */
.section--cta .cta__wrap { display: grid; place-items: center; text-align: center; gap: var(--space-2); background: var(--brand); color: #fff; border: none; padding: var(--space-5); border-radius: var(--radius-lg); box-shadow: var(--shadow-2); position: relative; overflow: hidden; isolation: isolate; }
.section--cta .cta__wrap::before { content: ""; position: absolute; inset: 0; background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E"); opacity: 0.3; }
.section--cta h2 { color: #fff; }
.section--cta p { color: rgba(255, 255, 255, 0.9); max-width: 50ch; margin-bottom: var(--space-2); font-size: 1.1rem; }
.section--cta .btn { --_bg: #fff; --_color: var(--brand); box-shadow: 0 10px 20px rgba(0,0,0,0.2); }
.section--cta .btn:hover { transform: translateY(-3px); box-shadow: 0 15px 30px rgba(0,0,0,0.3); }


/* Footer */
.footer { border-top: 1px solid var(--line); background: color-mix(in oklab, var(--bg) 90%, var(--card)); }
.footer__grid { display: grid; gap: var(--space-3); grid-template-columns: 2fr 1fr 1fr; padding-block: var(--space-4); }
.footer__nav { display: grid; gap: 8px; }
.footer__nav a { color: var(--text); text-decoration: none; opacity: .8; }
.footer__copy { align-self: end; color: var(--muted); }


/* Social vertical bar (unique icons + animation) */
.socialbar { position: fixed; top: 50%; left: 0; transform: translateY(-50%); z-index: 40; }
.socialbar ul { list-style: none; display: grid; gap: 6px; }
.social { display: flex; align-items: center; gap: 0; padding: 0; height: 44px; width: 44px; border-radius: 0 8px 8px 0; background: var(--card); border: 1px solid var(--line); border-left: none; box-shadow: var(--shadow-1); transition: width .3s cubic-bezier(0.175, 0.885, 0.32, 1.275), background .3s ease, transform .25s ease; position: relative; overflow: visible; justify-content: center; }
.social svg { min-width: 20px; width: 20px; height: 20px; fill: currentColor; color: var(--text); }
.social__name { font-size: 0.85rem; font-weight: 700; white-space: nowrap; opacity: 0; max-width: 0; overflow: hidden; transform: translateX(-6px); transition: opacity .2s ease, max-width .3s ease, transform .25s ease; color: var(--text); }
.social:hover, .social:focus-visible { width: 140px; justify-content: flex-start; gap: 10px; padding-left: 14px; background: color-mix(in oklab, var(--card) 90%, var(--brand)); transform: translateX(0); }
.social:hover .social__name, .social:focus-visible .social__name { opacity: 1; max-width: 110px; margin-left: 0; transform: translateX(0); }
.social::after { content: none; }
/* Ensure tooltip is above others */
.social { z-index: 41; }

/* Socialbar responsive: tablet/mobile -> bottom horizontal compact bar */
/* Socialbar responsive: moved to responsive.css */


/* Floating buttons */
.fab { position: fixed; bottom: 18px; display: grid; place-items: center; width: 54px; height: 54px; border-radius: 50%; background: var(--brand); color: #fff; border: none; box-shadow: var(--shadow-2); cursor: pointer; z-index: 45; }

.fab svg { width: 26px; height: 26px; fill: currentColor; }
.fab--whatsapp { right: 18px; background: #25D366; }
/* Improved Scroll Up Button */
.fab--totop { right: 24px; width: 42px; height: 42px; border-radius: 8px; transform: translateY(-20px) rotate(45deg); background: var(--brand-2); box-shadow: 0 8px 16px rgba(245, 95, 68, 0.3); z-index: 90; transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); opacity: 0; visibility: hidden; }
.fab--totop svg { transform: rotate(-45deg); width: 20px; height: 20px; stroke-width: 3px; }
.fab--totop.is-visible { opacity: 1; visibility: visible; transform: translateY(0) rotate(45deg); }
.fab--totop:hover { background: var(--brand); transform: translateY(-5px) rotate(45deg) scale(1.1); box-shadow: 0 12px 24px rgba(14, 78, 181, 0.4); }
.fab--drawer { left: 18px; }

/* Drawer */
.drawer { position: fixed; left: 12px; right: 12px; bottom: 12px; z-index: 60; transform: translateY(110%); transition: transform .35s ease; }
.drawer[data-open="true"] { transform: translateY(0); }
.drawer__content { margin-left: auto; max-width: 400px; background: var(--card); border: 1px solid var(--line); border-radius: var(--radius-lg); padding: var(--space-3); box-shadow: var(--shadow-2); }
.drawer__links { display: grid; gap: 10px; margin-block: var(--space-2); }
.drawer__links a { text-decoration: none; color: var(--text); opacity: .9; }
.drawer__close { width: 100%; }

/* Utilities */
.skip-link { position: absolute; left: -9999px; top: auto; width: 1px; height: 1px; overflow: hidden; }
.skip-link:focus { position: fixed; left: 12px; top: 12px; width: auto; height: auto; background: var(--card); color: var(--text); padding: 8px 12px; border-radius: 10px; border: 1px solid var(--line); z-index: 100; }

.checklist { display: grid; gap: 8px; margin-top: var(--space-2); }
.checklist li { list-style: none; position: relative; padding-left: 26px; }
.checklist li::before { content: ""; position: absolute; left: 0; top: 6px; width: 14px; height: 14px; border-radius: 50%; background: var(--accent); border: 2px solid color-mix(in oklab, var(--accent) 60%, transparent); }


/* Responsive hero grid on small screens */
/* Responsive hero grid on small screens: moved to responsive.css */


/* Accessibility focus ring */
:focus-visible { outline: 2px solid color-mix(in oklab, var(--brand) 60%, var(--accent)); outline-offset: 2px; border-radius: 6px; }

/* Brand logo visibility across themes */
body[data-theme="light"] .brand__logo--light { display: block; }
body[data-theme="light"] .brand__logo--dark { display: none; }
body[data-theme="dark"] .brand__logo--light { display: none; }
body[data-theme="dark"] .brand__logo--dark { display: block; }

/* Enhancements per request */
/* Social tooltips showing icon name */
/* Removing old social tooltip as we have new expansion effect */

/* Buttons icon sizing and screen-reader utility */
.sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 1px, 1px); white-space: nowrap; border: 0; }
.btn .icon { font-size: 1.1em; line-height: 1; }

/* Hero: remove any box/background around Lottie container */
.section--hero .hero__right { background: transparent !important; box-shadow: none !important; border-radius: 0 !important; overflow: visible !important; position: relative; }
.section--hero .hero__right::after { content: none !important; }

/* Hero: unique animated gradient text */
.txt-rotate { background-size: 200% auto; animation: shine 6s linear infinite; }
@keyframes shine { to { background-position: 200% center; } }

/* About: subtle accent rail */
.section--about::before { content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 6px; background: var(--brand); border-radius: 0 6px 6px 0; opacity: .2; }


/* Services: numbered cards */
.section--services .cards { counter-reset: svc; }
.section--services .card { padding-top: calc(var(--space-3) + 10px); }
.section--services .card::after { content: counter(svc, decimal-leading-zero); counter-increment: svc; position: absolute; top: 8px; right: 12px; font-weight: 800; font-family: var(--font-primary); color: color-mix(in oklab, var(--brand) 70%, var(--text)); opacity: .18; font-size: clamp(1.2rem, 2vw, 1.6rem); }

/* Why Me: animated blob */
.media-blob { animation: blobMove 10s ease-in-out infinite alternate; }
@keyframes blobMove { 0% { filter: blur(6px); transform: scale(1) translate(0, 0); } 100% { filter: blur(10px); transform: scale(1.06) translate(4px, -6px); } }

/* FAQ: visual polish */
.section--faq details { border-left: 3px solid var(--brand); }
.section--faq summary { cursor: pointer; font-weight: 700; list-style: none; }
.section--faq summary::-webkit-details-marker { display: none; }
.section--faq summary::after { content: '+'; float: right; font-weight: 700; transition: transform .2s ease; }
.section--faq details[open] summary::after { content: '–'; }

/* Contact: full design */
.contact__form { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius-lg); padding: var(--space-4); box-shadow: var(--shadow-1); display: grid; gap: var(--space-3); }
.contact__form .btn { justify-self: start; }
.contact__form .btn { justify-self: start; }

.contact__form label span { display: block; font-weight: 700; margin-bottom: 6px; }
.contact__form input, .contact__form textarea { width: 100%; background: color-mix(in oklab, var(--bg) 88%, var(--card)); border: 1px solid var(--line); border-radius: 10px; padding: 10px 12px; color: var(--text); }
.contact__form input:focus, .contact__form textarea:focus { border-color: color-mix(in oklab, var(--brand) 60%, var(--accent)); outline: none; box-shadow: 0 0 0 3px color-mix(in oklab, var(--brand) 20%, transparent); }

/* Footer: theme-aware logo and accent */
.footer { position: relative; }
.footer__logo--dark { display: none; }
body[data-theme="dark"] .footer__logo--dark { display: inline; }
body[data-theme="dark"] .footer__logo--light { display: none; }
body[data-theme="light"] .footer__logo--light { display: inline; }
body[data-theme="light"] .footer__logo--dark { display: none; }
.footer::before { content: ""; position: absolute; inset: 0 0 auto 0; height: 3px; background: var(--brand); opacity: .3; }


/* Header blur fallback for browsers not supporting color-mix */
@supports not (background: color-mix(in oklab, white 50%, black)) {
  .header { background: rgba(0,0,0,.2); }
}

/* Global Scroll Reveal Animation */
.reveal { opacity: 0; transform: translateY(30px); transition: opacity 0.8s ease, transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1); will-change: opacity, transform; }
.reveal.active { opacity: 1; transform: translateY(0); }
.reveal.reveal--left { transform: translateX(-22px); }
.reveal.reveal--right { transform: translateX(22px); }
.reveal.reveal--scale { transform: translateY(16px) scale(.98); }
.reveal.reveal--left.active, .reveal.reveal--right.active { transform: translateX(0); }
.reveal.reveal--scale.active { transform: translateY(0) scale(1); }
/* Staggering for children if needed */
.reveal-stagger > * { opacity: 0; transform: translateY(20px); transition: opacity 0.5s ease, transform 0.5s ease; }
.reveal-stagger.active > * { opacity: 1; transform: translateY(0); }
.reveal-stagger.active > *:nth-child(1) { transition-delay: 0.1s; }
.reveal-stagger.active > *:nth-child(2) { transition-delay: 0.2s; }
.reveal-stagger.active > *:nth-child(3) { transition-delay: 0.3s; }
.reveal-stagger.active > *:nth-child(4) { transition-delay: 0.4s; }

